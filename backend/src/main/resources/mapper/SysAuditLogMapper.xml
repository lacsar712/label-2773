<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.employee.mapper.SysAuditLogMapper">

    <resultMap id="SysAuditLogMap" type="com.example.employee.entity.SysAuditLog">
        <id column="id" property="id"/>
        <result column="operator_id" property="operatorId"/>
        <result column="operator_name" property="operatorName"/>
        <result column="operator_username" property="operatorUsername"/>
        <result column="operator_role_id" property="operatorRoleId"/>
        <result column="operator_role_code" property="operatorRoleCode"/>
        <result column="operator_role_name" property="operatorRoleName"/>
        <result column="operation_type" property="operationType"/>
        <result column="target_module" property="targetModule"/>
        <result column="target_module_name" property="targetModuleName"/>
        <result column="target_record_id" property="targetRecordId"/>
        <result column="target_record_name" property="targetRecordName"/>
        <result column="before_snapshot" property="beforeSnapshot"/>
        <result column="after_snapshot" property="afterSnapshot"/>
        <result column="request_ip" property="requestIp"/>
        <result column="user_agent" property="userAgent"/>
        <result column="browser" property="browser"/>
        <result column="os" property="os"/>
        <result column="device" property="device"/>
        <result column="operation_time" property="operationTime"/>
        <result column="archived" property="archived"/>
    </resultMap>

    <select id="selectByConditions" resultMap="SysAuditLogMap">
        SELECT * FROM sys_audit_log
        <where>
            <if test="targetModule != null and targetModule != ''">
                AND target_module = #{targetModule}
            </if>
            <if test="operationType != null">
                AND operation_type = #{operationType}
            </if>
            <if test="operatorId != null">
                AND operator_id = #{operatorId}
            </if>
            <if test="operatorName != null and operatorName != ''">
                AND operator_name LIKE CONCAT('%', #{operatorName}, '%')
            </if>
            <if test="startTime != null">
                AND operation_time >= #{startTime}
            </if>
            <if test="endTime != null">
                AND operation_time &lt;= #{endTime}
            </if>
            <if test="targetRecordId != null and targetRecordId != ''">
                AND target_record_id = #{targetRecordId}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (
                    target_record_name LIKE CONCAT('%', #{keyword}, '%')
                    OR operator_name LIKE CONCAT('%', #{keyword}, '%')
                    OR before_snapshot LIKE CONCAT('%', #{keyword}, '%')
                    OR after_snapshot LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
        </where>
        ORDER BY operation_time DESC
    </select>

    <select id="selectByOperatorIdOrderByTime" resultMap="SysAuditLogMap">
        SELECT * FROM sys_audit_log
        WHERE operator_id = #{operatorId}
        ORDER BY operation_time DESC
    </select>

    <select id="selectByTargetRecordOrderByTime" resultMap="SysAuditLogMap">
        SELECT * FROM sys_audit_log
        WHERE target_module = #{targetModule} AND target_record_id = #{targetRecordId}
        ORDER BY operation_time DESC
    </select>

    <update id="archiveOldLogs">
        UPDATE sys_audit_log
        SET archived = 1
        WHERE operation_time &lt;= #{cutoffTime} AND archived = 0
    </update>

</mapper>
